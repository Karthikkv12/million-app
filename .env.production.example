# ── OptionFlow Production Environment Variables ───────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit the real .env to git.
# Store these in AWS Secrets Manager / Parameter Store for ECS.

# ── Database ──────────────────────────────────────────────────────────────────
# RDS PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=postgresql://optionflow:CHANGE_ME@your-rds-endpoint.rds.amazonaws.com:5432/optionflow

# ── Auth / JWT ────────────────────────────────────────────────────────────────
# Generate a strong secret: python3 -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET=CHANGE_ME_USE_SECRETS_MANAGER
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slash)
# Add your Vercel production URL and any custom domain
CORS_ALLOW_ORIGINS=https://your-app.vercel.app,https://optflw.com

# ── App ───────────────────────────────────────────────────────────────────────
# Set to "production" to suppress debug output
ENVIRONMENT=production

# ── Optional: Google AI / OpenAI (if used) ────────────────────────────────────
GOOGLE_API_KEY=
OPENAI_API_KEY=
